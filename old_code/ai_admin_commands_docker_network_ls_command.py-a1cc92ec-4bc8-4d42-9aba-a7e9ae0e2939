import subprocess

import json

from typing import Dict, Any, Optional, List

from ai_admin.commands.base_unified_command import BaseUnifiedCommand

from ai_admin.security.docker_security_adapter import DockerSecurityAdapter

class DockerNetworkLsCommand:
    
    
    """List Docker networks."""
    
    
    name = "docker_network_ls"
    
    
    def __init__(self):
        """Initialize Docker network ls command."""
        super().__init__()
        self.security_adapter = DockerSecurityAdapter()
    
    
    async def execute(
        self,
        format_output: Optional[str] = None,
        filter_network: Optional[str] = None,
        quiet: bool = False,
        no_trunc: bool = False,
        user_roles: Optional[List[str]] = None,
        **kwargs,
    ) -> SuccessResult:
        """Execute Docker network ls command with unified security.
    
            Args:
                format_output: Output format (table, json, etc.)
                filter_network: Filter by network name
                quiet: Only display network IDs
                no_trunc: Don't truncate output
                user_roles: List of user roles for security validation
    
            Returns:
                Success result with networks information
            """
        # Use unified security approach
        return await super().execute(
            format_output=format_output,
            filter_network=filter_network,
            quiet=quiet,
            no_trunc=no_trunc,
            user_roles=user_roles,
            **kwargs,
        )
    
    
    def _get_default_operation(self) -> str:
        """Get default operation name for Docker network ls command."""
        return "docker:network_ls"
    
    
    async def _execute_command_logic(self, **kwargs) -> Dict[str, Any]:
        """Execute Docker network ls command logic."""
        return await self._list_networks(**kwargs)
    
    
    async def _list_networks(
        self,
        format_output: Optional[str] = None,
        filter_network: Optional[str] = None,
        quiet: bool = False,
        no_trunc: bool = False,
        **kwargs,
    ) -> Dict[str, Any]:
        """List Docker networks."""
        try:
            # Build Docker command
            cmd = ["docker", "network", "ls"]
    
            # Add options
            if quiet:
                cmd.append("-q")
    
            if no_trunc:
                cmd.append("--no-trunc")
    
            # Add format
            if format_output:
                cmd.extend(["--format", format_output])
    
            # Add filter
            if filter_network:
                cmd.extend(["--filter", f"name={filter_network}"])
    
            # Execute command
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
    
            if result.returncode != 0:
                raise NetworkError(f"Failed to list Docker networks: {result.stderr}")
    
            # Parse output
            networks = []
            if format_output == "json" or quiet:
                try:
                    networks = json.loads(result.stdout) if result.stdout.strip() else []
                except json.JSONDecodeError:
                    networks = [{"id": line.strip()} for line in result.stdout.strip().split("\n") if line.strip()]
            else:
                # Parse table format
                lines = result.stdout.strip().split("\n")
                if len(lines) > 1:
                    headers = lines[0].split()
                    for line in lines[1:]:
                        if line.strip():
                            parts = line.split()
                            if len(parts) >= len(headers):
                                network = dict(zip(headers, parts))
                                networks.append(network)
    
            return {
                "message": f"Found {len(networks)} Docker networks",
                "networks": networks,
                "count": len(networks),
                "format_output": format_output,
                "filter_network": filter_network,
                "quiet": quiet,
                "no_trunc": no_trunc,
                "raw_output": result.stdout,
                "command": " ".join(cmd),
            }
    
        except subprocess.TimeoutExpired as e:
            raise NetworkError(f"Docker network ls command timed out: {str(e)}")
        except NetworkError as e:
            raise NetworkError(f"Docker network ls failed: {str(e)}")
    
    
    @classmethod
    def get_schema(cls) -> Dict[str, Any]:
        """Get JSON schema for Docker network ls command parameters."""
        return {
            "type": "object",
            "properties": {
                "format_output": {
                    "type": "string",
                    "description": "Output format",
                },
                "filter_network": {
                    "type": "string",
                    "description": "Filter by network name",
                },
                "quiet": {
                    "type": "boolean",
                    "description": "Only display network IDs",
                    "default": False,
                },
                "no_trunc": {
                    "type": "boolean",
                    "description": "Don't truncate output",
                    "default": False,
                },
                "user_roles": {
                    "type": "array",
                    "items": {"type": "string"},
                    "description": "List of user roles for security validation",
                },
            },
            "additionalProperties": False,
        }
    