\"\"\"Tests for queue size and per-type limits.\"\"\"

import asyncio
import pytest
from mcp_proxy_adapter.queue.integration import QueueManagerIntegration
from ai_admin.jobs.system_job import SystemJob


@pytest.mark.asyncio
async def test_max_queue_size_eviction():
    \"\"\"Test that oldest job is evicted when max_queue_size is reached.\"\"\"
    q = QueueManagerIntegration(in_memory=True, max_concurrent_jobs=0, max_queue_size=2)
    await q.start()
    try:
        await q.add_job(SystemJob, 'job_1', {'operation_type': 'system_monitor',
            'include_gpu': False, 'include_temperature': False, 'include_processes': False})
        await q.add_job(SystemJob, 'job_2', {'operation_type': 'system_monitor',
            'include_gpu': False, 'include_temperature': False, 'include_processes': False})
        await q.add_job(SystemJob, 'job_3', {'operation_type': 'system_monitor',
            'include_gpu': False, 'include_temperature': False, 'include_processes': False})
        jobs = await q.list_jobs()
        job_ids = [j.job_id for j in jobs]
        # job_1 should be evicted (oldest)
        assert 'job_1' not in job_ids
        assert 'job_2' in job_ids
        assert 'job_3' in job_ids
    finally:
        await q.stop()
"""
)
