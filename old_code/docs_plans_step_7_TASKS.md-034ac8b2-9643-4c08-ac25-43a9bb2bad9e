import asyncio
import pytest
from mcp_proxy_adapter.queue.integration import QueueManagerIntegration
from ai_admin.jobs.system_job import SystemJob


@pytest.mark.asyncio
async def test_completed_job_cleaned_up_after_retention():
    \"\"\"Test that completed jobs are removed after retention period.\"\"\"
    q = QueueManagerIntegration(
        in_memory=True,
        max_concurrent_jobs=1,
        completed_job_retention_seconds=1  # 1 second for test
    )
    await q.start()
    try:
        await q.add_job(SystemJob, 'cleanup_test_1', {
            'operation_type': 'system_monitor',
            'include_gpu': False, 'include_temperature': False, 'include_processes': False
        })
        # Wait for completion
        for _ in range(20):
            s = await q.get_job_status('cleanup_test_1')
            if s.status == 'completed':
                break
            await asyncio.sleep(0.3)
        # Wait for retention to expire + cleanup cycle
        await asyncio.sleep(3)
        # Job should be gone
        jobs = await q.list_jobs()
        job_ids = [j.job_id for j in jobs]
        assert 'cleanup_test_1' not in job_ids
    finally:
        await q.stop()
"""
)
