"""Module manager."""

from ai_admin.core.custom_exceptions import AuthenticationError, ConfigurationError, ValidationError
import json
import os
from datetime import datetime
from typing import Dict, Any, Optional, List
from mcp_proxy_adapter.core.settings import (
    add_custom_settings,
    get_custom_settings,
    get_custom_setting_value,
    set_custom_setting_value,
)
import logging
from .config.ssl_config import SSLConfig
from .config.roles_config import RolesConfig
from .config.token_config import TokenManager
from .helpers import is_feature_enabled

class AIAdminSettingsManager:
    """
    Settings manager for AI Admin server.

    This class provides:
    1. Loading of custom settings from JSON files
    2. Management of credentials and sensitive data
    3. Feature toggles and configuration validation
    4. Integration with the framework's settings system
    """

    def __init__(
        self,
        config_file: str = "config/config.json",
        credentials_file: str = "config/auth.json",
    ):
        """
        Initialize the AI Admin settings manager.

        Args:
            config_file: Path to main configuration JSON file
            credentials_file: Path to credentials JSON file
        """
        self.config_file = config_file
        self.credentials_file = credentials_file
        self.logger = logging.getLogger("ai_admin.settings")
        self._ssl_config: Optional[SSLConfig] = None
        self._roles_config: Optional[RolesConfig] = None
        self._token_manager: Optional[TokenManager] = None
        self._load_settings()

    def _load_settings(self) -> None:
        """Load settings from configuration and credentials files."""
        try:
            # Load main configuration
            if os.path.exists(self.config_file):
                with open(self.config_file, "r", encoding="utf-8") as f:
                    config_settings = json.load(f)

                self.logger.info(f"📁 Loaded configuration from: {self.config_file}")

                # Add to framework's settings system
                add_custom_settings(config_settings)

            else:
                self.logger.warning(
                    f"⚠️  Configuration file not found: {self.config_file}"
                )

            # Load credentials
            if os.path.exists(self.credentials_file):
                with open(self.credentials_file, "r", encoding="utf-8") as f:
                    credentials = json.load(f)

                self.logger.info(f"🔐 Loaded credentials from: {self.credentials_file}")

                # Add credentials to settings system
                add_custom_settings({"credentials": credentials})

            else:
                self.logger.warning(
                    f"⚠️  Credentials file not found: {self.credentials_file}"
                )

        except ConfigurationError as e:
            self.logger.error(f"❌ Failed to load settings: {e}")

        # Load SSL configuration
        self.load_ssl_config()

        # Load roles configuration
        self.load_roles_config()

        # Load token configuration
        self.load_token_config()

    def get_application_name(self) -> str:
        """Get application name."""
        return str(get_custom_setting_value(
            "ai_admin.application.name", "AI Admin - Enhanced MCP Server"
        ))

    def get_application_version(self) -> str:
        """Get application version."""
        return str(get_custom_setting_value("ai_admin.application.version", "2.0.0"))

    def get_environment(self) -> str:
        """Get application environment."""
        return str(get_custom_setting_value(
            "ai_admin.application.environment", "production"
        ))

    def is_feature_enabled(self, feature_name: str) -> bool:
        """Check if a feature is enabled."""
        return bool(get_custom_setting_value(f"ai_admin.features.{feature_name}", False))

    def get_docker_credentials(self) -> Dict[str, Any]:
        """Get Docker credentials."""
        result = get_custom_setting_value("credentials.docker", {})
        return result if isinstance(result, dict) else {}

    def get_github_credentials(self) -> Dict[str, Any]:
        """Get GitHub credentials."""
        result = get_custom_setting_value("credentials.github", {})
        return result if isinstance(result, dict) else {}

    def get_vast_credentials(self) -> Dict[str, Any]:
        """Get Vast.ai credentials."""
        result = get_custom_setting_value("credentials.vast", {})
        return result if isinstance(result, dict) else {}

    def get_ftp_credentials(self) -> Dict[str, Any]:
        """Get FTP credentials."""
        result = get_custom_setting_value("credentials.ftp", {})
        return result if isinstance(result, dict) else {}

    def get_ollama_credentials(self) -> Dict[str, Any]:
        """Get Ollama credentials."""
        result = get_custom_setting_value("credentials.ollama", {})
        return result if isinstance(result, dict) else {}

    def get_command_setting(
        self, command_name: str, setting_name: str, default: Any = None
    ) -> Any:
        """Get custom command setting."""
        return get_custom_setting_value(
            f"ai_admin.custom_commands.{command_name}.{setting_name}", default
        )

    def get_hook_setting(
        self, hook_name: str, setting_name: str, default: Any = None
    ) -> Any:
        """Get hook setting."""
        return get_custom_setting_value(
            f"ai_admin.hooks.{hook_name}.{setting_name}", default
        )

    def set_custom_setting(self, key: str, value: Any) -> None:
        """Set a custom setting."""
        set_custom_setting_value(key, value)
        self.logger.info(f"🔧 Set custom setting: {key} = {value}")

    def get_custom_setting_value(self, key: str, default: Any = None) -> Any:
        """Get a custom setting value."""
        return get_custom_setting_value(key, default)

    def get_all_settings(self) -> Dict[str, Any]:
        """Get all custom settings."""
        result = get_custom_settings()
        return result if isinstance(result, dict) else {}

    def reload_settings(self) -> None:
        """Reload settings from files."""
        self.logger.info("🔄 Reloading AI Admin settings...")
        self._load_settings()
        self.logger.info("✅ AI Admin settings reloaded")

    def validate_settings(self) -> Dict[str, Any]:
        """
        Validate current settings and return validation results.

        Returns:
            Dictionary with validation results
        """
        validation_results: Dict[str, Any] = {"valid": True, "errors": [], "warnings": []}

        # Validate required settings
        required_settings = [
            "ai_admin.application.name",
            "ai_admin.application.version",
            "ai_admin.features.docker_operations",
        ]

        for setting in required_settings:
            if get_custom_setting_value(setting) is None:
                validation_results["valid"] = False
                validation_results["errors"].append(
                    f"Missing required setting: {setting}"
                )

        # Validate feature dependencies
        if self.is_feature_enabled("docker_operations"):
            docker_creds = self.get_docker_credentials()
            if not docker_creds.get("username") or not docker_creds.get("token"):
                validation_results["warnings"].append(
                    "Docker operations enabled but credentials are missing"
                )

        if self.is_feature_enabled("vast_operations"):
            vast_creds = self.get_vast_credentials()
            if not vast_creds.get("api_key"):
                validation_results["warnings"].append(
                    "Vast.ai operations enabled but API key is missing"
                )

        if self.is_feature_enabled("ftp_operations"):
            ftp_creds = self.get_ftp_credentials()
            if not ftp_creds.get("host") or not ftp_creds.get("user"):
                validation_results["warnings"].append(
                    "FTP operations enabled but credentials are missing"
                )

        return validation_results

    def print_settings_summary(self) -> None:
        """Print a summary of current settings."""
        self.logger.info("📊 AI Admin Settings Summary:")
        self.logger.info(
            f"   Application: {self.get_application_name()} v{self.get_application_version()}"
        )
        self.logger.info(f"   Environment: {self.get_environment()}")

        # Features
        features = []
        feature_list = [
            "advanced_hooks",
            "custom_commands",
            "data_transformation",
            "command_interception",
            "performance_monitoring",
            "custom_settings_manager",
            "queue_system",
            "ftp_operations",
            "docker_operations",
            "vast_operations",
            "github_operations",
            "kubernetes_operations",
            "ollama_operations",
        ]

        for feature in feature_list:
            if self.is_feature_enabled(feature):
                features.append(feature)

        self.logger.info(
            f"   Enabled Features: {', '.join(features) if features else 'None'}"
        )

        # Security
        auth_enabled = get_custom_setting_value(
            "ai_admin.security.enable_authentication", False
        )
        rate_limiting = get_custom_setting_value(
            "ai_admin.security.rate_limiting.enabled", False
        )
        self.logger.info(
            f"   Security: Auth={auth_enabled}, Rate Limiting={rate_limiting}"
        )

        # Monitoring
        metrics_enabled = get_custom_setting_value(
            "ai_admin.monitoring.enable_metrics", False
        )
        self.logger.info(f"   Monitoring: Metrics={metrics_enabled}")

        # Credentials status
        creds_status = []
        if self.get_docker_credentials():
            creds_status.append("Docker")
        if self.get_github_credentials():
            creds_status.append("GitHub")
        if self.get_vast_credentials():
            creds_status.append("Vast.ai")
        if self.get_ftp_credentials():
            creds_status.append("FTP")
        if self.get_ollama_credentials():
            creds_status.append("Ollama")

        self.logger.info(
            f"   Credentials: {', '.join(creds_status) if creds_status else 'None'}"
        )

    def load_ssl_config(self) -> None:
        """
        Load SSL configuration from settings.

        This method loads SSL configuration from the current settings
        and creates an SSLConfig instance for validation and management.
        """
        try:
            # Get SSL configuration from settings
            ssl_settings = get_custom_setting_value("ssl", {})
            cert_settings = get_custom_setting_value("certificates", {})

            # Combine SSL and certificate settings
            config_data = {"ssl": ssl_settings, "certificates": cert_settings}

            # Create SSL config instance
            self._ssl_config = SSLConfig(config_data, auto_validate=False)

            self.logger.info("🔒 SSL configuration loaded successfully")

        except ConfigurationError as e:
            self.logger.error(f"❌ Failed to load SSL configuration: {e}")
            self._ssl_config = None

    def validate_ssl_settings(self) -> Dict[str, Any]:
        """
        Validate SSL settings and return validation results.

        Returns:
            Dict[str, Any]: Validation results with status and details.
        """
        validation_results: Dict[str, Any] = {
            "valid": True,
            "errors": [],
            "warnings": [],
            "ssl_mode": None,
            "ssl_enabled": False,
        }

        try:
            if self._ssl_config is None:
                self.load_ssl_config()

            if self._ssl_config is None:
                validation_results["valid"] = False
                validation_results["errors"].append("SSL configuration not available")
                return validation_results

            # Validate SSL configuration
            self._ssl_config.validate_config()

            # Get SSL mode and status
            validation_results["ssl_mode"] = self._ssl_config.get_ssl_mode().value
            validation_results["ssl_enabled"] = self._ssl_config.is_ssl_enabled()

            # Check for potential issues
            if self._ssl_config.is_ssl_enabled():
                cert_paths = self._ssl_config.get_certificate_paths()
                if not cert_paths.server_cert:
                    validation_results["warnings"].append(
                        "SSL enabled but server certificate not specified"
                    )
                if not cert_paths.server_key:
                    validation_results["warnings"].append(
                        "SSL enabled but server key not specified"
                    )

            if self._ssl_config.is_mtls_enabled():
                cert_paths = self._ssl_config.get_certificate_paths()
                if not cert_paths.ca_cert:
                    validation_results["warnings"].append(
                        "mTLS enabled but CA certificate not specified"
                    )

            self.logger.info(
                f"✅ SSL settings validation completed: {validation_results['ssl_mode']}"
            )

        except ValueError as e:
            validation_results["valid"] = False
            validation_results["errors"].append(str(e))
            self.logger.error(f"❌ SSL settings validation failed: {e}")

        except ValidationError as e:
            validation_results["valid"] = False
            validation_results["errors"].append(f"SSL validation error: {e}")
            self.logger.error(f"❌ SSL settings validation error: {e}")

        return validation_results

    def get_ssl_config(self) -> Optional[SSLConfig]:
        """
        Get SSL configuration instance.

        Returns:
            Optional[SSLConfig]: SSL configuration instance or None if not available.
        """
        if self._ssl_config is None:
            self.load_ssl_config()
        return self._ssl_config

    def update_ssl_config(self, new_ssl_settings: Dict[str, Any]) -> None:
        """
        Update SSL configuration with new settings.

        Args:
            new_ssl_settings: New SSL settings dictionary.
        """
        try:
            # Update settings in the framework
            set_custom_setting_value("ssl", new_ssl_settings.get("ssl", {}))
            set_custom_setting_value(
                "certificates", new_ssl_settings.get("certificates", {})
            )

            # Reload SSL configuration
            self.load_ssl_config()

            self.logger.info("🔒 SSL configuration updated successfully")

        except ConfigurationError as e:
            self.logger.error(f"❌ Failed to update SSL configuration: {e}")
            raise

