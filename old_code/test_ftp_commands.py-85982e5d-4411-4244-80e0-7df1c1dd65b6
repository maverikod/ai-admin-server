import asyncio
import aiohttp
import json
import sys
from typing import Dict, Any

BASE_URL = "http://localhost:20001"

async def test_command(session: aiohttp.ClientSession, command: str, params: Dict[str, Any]) -> Dict[str, Any]:
    """Test a single command."""
    try:
        async with session.post(
            f"{BASE_URL}/cmd",
            json={"command": command, **params},
            timeout=aiohttp.ClientTimeout(total=60)
        ) as response:
            result = await response.json()
            return {
                "command": command,
                "status": response.status,
                "success": response.status == 200,
                "result": result
            }
    except Exception as e:
        return {
            "command": command,
            "status": 0,
            "success": False,
            "error": str(e)
        }

