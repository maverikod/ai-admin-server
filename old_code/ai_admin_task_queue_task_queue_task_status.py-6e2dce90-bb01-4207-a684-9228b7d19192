class TaskStatus(Enum):
    """Task execution status with detailed error codes."""

    # Active states
    PENDING = "pending"
    RUNNING = "running"
    PAUSED = "paused"

    # Completion states
    COMPLETED = "completed"
    FAILED = "failed"
    CANCELLED = "cancelled"
    TIMEOUT = "timeout"

    # Intermediate states
    VALIDATING = "validating"
    PREPARING = "preparing"
    UPLOADING = "uploading"
    DOWNLOADING = "downloading"
    BUILDING = "building"
    PULLING = "pulling"



