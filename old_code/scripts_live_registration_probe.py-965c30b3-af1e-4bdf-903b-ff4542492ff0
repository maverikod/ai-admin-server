"""Live probe: await RegistrationManager.register_with_proxy."""

from __future__ import annotations

import asyncio
import logging
import sys
from pathlib import Path

from mcp_proxy_adapter.api.core.registration_manager.manager import RegistrationManager
from mcp_proxy_adapter.config import get_config

ROOT = Path(__file__).resolve().parent.parent
CFG = ROOT / "config" / "config.json"


async def run() -> int:
    logging.basicConfig(level=logging.INFO)
    cfg = get_config()
    cfg.config_path = str(CFG)
    cfg.load_config()
    data = cfg.get_all()
    reg = data.get("registration") or {}
    if not reg.get("enabled"):
        print("registration.enabled is false; abort")
        return 2
    mgr = RegistrationManager()
    ok = await mgr.register_with_proxy(data)
    print("register_with_proxy returned:", ok)
    return 0 if ok else 1


def main() -> None:
    raise SystemExit(asyncio.run(run()))


if __name__ == "__main__":
    main()
