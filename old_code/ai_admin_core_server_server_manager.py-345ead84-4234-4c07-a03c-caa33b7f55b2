    async def authenticate_client_mtls(
        self,
        certificate_data: bytes,
        certificate_chain: Optional[List[bytes]] = None,
        required_permissions: Optional[List[str]] = None,
        resource: Optional[str] = None,
    ) -> Dict[str, Any]:
        """
        Authenticate client using mTLS.

        Args:
            certificate_data: Client certificate data in DER format
            certificate_chain: Optional certificate chain for validation
            required_permissions: Optional list of required permissions
            resource: Optional resource identifier

        Returns:
            Authentication result dictionary

        Raises:
            AppCreationError: If mTLS authentication fails
        """
        if not self.mtls_auth_manager:
            raise AppCreationError(
                "mTLS authentication manager not available",
                app_config={"mtls_enabled": False},
            )

        try:
            return await self.mtls_auth_manager.authenticate_client(
                certificate_data=certificate_data,
                certificate_chain=certificate_chain,
                required_permissions=required_permissions,
                resource=resource,
            )
        except SSLError as e:
            error_msg = f"mTLS client authentication failed: {e}"
            self.logger.error(error_msg)
            raise AppCreationError(
                error_msg,
                app_config={"mtls_enabled": True},
                details={"exception": str(e)},
            )

