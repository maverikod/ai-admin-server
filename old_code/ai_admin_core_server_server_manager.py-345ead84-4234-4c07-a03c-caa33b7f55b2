"""Module server_manager."""

from ai_admin.core.custom_exceptions import AuthenticationError, ConfigurationError, CustomError, SSLError, ValidationError
from typing import Dict, Any, Optional, List
from fastapi import FastAPI
import logging
from ai_admin.core.app_factory import AppFactory
from ai_admin.core.factory_exceptions import AppCreationError
from ai_admin.core.ssl_context_manager import SSLContextManager, SSLContextType
from ai_admin.core.mtls_auth_manager import MTLSAuthManager
from ai_admin.core.token_auth_manager import TokenAuthManager
from .factory import create_server, run_ai_admin_server

class ServerManager:
    """Manager for AI Admin server configuration and lifecycle."""

    def __init__(
        self,
        config_path: Optional[str] = None,
        host: str = "0.0.0.0",
        port: int = 8000,
        workers: int = 1,
        reload: bool = False,
        log_level: str = "info",
    ):
        """
        Initialize server manager.

        Args:
            config_path: Path to configuration file
            host: Server host address
            port: Server port
            workers: Number of worker processes
            reload: Whether to enable auto-reload
            log_level: Logging level
        """
        self.config_path = config_path
        self.host = host
        self.port = port
        self.workers = workers
        self.reload = reload
        self.log_level = log_level
        self.logger = logging.getLogger("ai_admin.server")

        # Initialize app factory
        self.app_factory = AppFactory(config_path=config_path)
        self.app: Optional[FastAPI] = None
        self.ssl_context_manager: Optional[SSLContextManager] = None
        self.mtls_auth_manager: Optional[MTLSAuthManager] = None
        self.token_auth_manager: Optional[TokenAuthManager] = None

    async def create_app(
        self,
        app_name: str = "AI Admin",
        app_version: str = "1.0.0",
        description: str = "AI Admin API Server",
        custom_commands: Optional[List] = None,
        custom_middleware: Optional[List] = None,
        enable_ssl: bool = True,
        enable_mtls: bool = True,
        enable_cors: bool = True,
        enable_token_auth: bool = True,
    ) -> FastAPI:
        """
        Create and configure FastAPI application.

        Args:
            app_name: Application name
            app_version: Application version
            description: Application description
            custom_commands: List of custom command classes
            custom_middleware: List of custom middleware functions
            enable_ssl: Whether to enable SSL support
            enable_mtls: Whether to enable mTLS support
            enable_cors: Whether to enable CORS support
            enable_token_auth: Whether to enable token-based authentication

        Returns:
            Configured FastAPI application

        Raises:
            AppCreationError: If application creation fails
        """
        try:
            self.logger.info(f"Creating AI Admin application: {app_name}")

            # Create application using factory
            self.app = await self.app_factory.create_app(
                app_name=app_name,
                app_version=app_version,
                description=description,
                custom_commands=custom_commands,
                custom_middleware=custom_middleware,
                enable_ssl=enable_ssl,
                enable_mtls=enable_mtls,
                enable_cors=enable_cors,
                enable_token_auth=enable_token_auth,
            )

            # Get SSL context manager and auth managers from app factory
            self.ssl_context_manager = self.app_factory.ssl_context_manager
            self.mtls_auth_manager = self.app_factory.mtls_auth_manager
            self.token_auth_manager = self.app_factory.token_auth_manager

            self.logger.info("AI Admin application created successfully")
            return self.app

        except ConfigurationError as e:
            error_msg = f"Failed to create AI Admin application: {e}"
            self.logger.error(error_msg)
            raise AppCreationError(
                error_msg,
                app_config={"name": app_name, "version": app_version},
                details={"exception": str(e)},
            )

    async def run_server(self, app: Optional[FastAPI] = None) -> None:
        """
        Run the server with the specified configuration.

        Args:
            app: FastAPI application to run (uses self.app if not provided)

        Raises:
            AppCreationError: If server startup fails
        """
        try:
            if app is None:
                app = self.app

            if app is None:
                raise AppCreationError(
                    "No application to run. Create application first.",
                    app_config={"host": self.host, "port": self.port},
                )

            self.logger.info(f"Starting AI Admin server on {self.host}:{self.port}")

            # Run server using app factory
            await self.app_factory.run_server(
                app=app,
                host=self.host,
                port=self.port,
                workers=self.workers,
                reload=self.reload,
                log_level=self.log_level,
            )

        except ConfigurationError as e:
            error_msg = f"Failed to run AI Admin server: {e}"
            self.logger.error(error_msg)
            raise AppCreationError(
                error_msg,
                app_config={"host": self.host, "port": self.port},
                details={"exception": str(e)},
            )

    def get_server_config(self) -> Dict[str, Any]:
        """
        Get current server configuration.

        Returns:
            Server configuration dictionary
        """
        return {
            "config_path": self.config_path,
            "host": self.host,
            "port": self.port,
            "workers": self.workers,
            "reload": self.reload,
            "log_level": self.log_level,
            "app_created": self.app is not None,
        }

    def update_config(
        self,
        host: Optional[str] = None,
        port: Optional[int] = None,
        workers: Optional[int] = None,
        reload: Optional[bool] = None,
        log_level: Optional[str] = None,
    ) -> None:
        """
        Update server configuration.

        Args:
            host: New host address
            port: New port
            workers: New number of workers
            reload: New reload setting
            log_level: New log level
        """
        if host is not None:
            self.host = host
        if port is not None:
            self.port = port
        if workers is not None:
            self.workers = workers
        if reload is not None:
            self.reload = reload
        if log_level is not None:
            self.log_level = log_level

        self.logger.info("Server configuration updated")

    async def initialize(self) -> None:
        """
        Initialize server manager.

        This method performs any necessary initialization tasks
        before creating and running the server.
        """
        try:
            self.logger.info("Initializing server manager")

            # Initialize any required components
            # The actual initialization is handled by AppFactory
            # when create_app is called

            self.logger.info("Server manager initialized successfully")

        except ConfigurationError as e:
            error_msg = f"Failed to initialize server manager: {e}"
            self.logger.error(error_msg)
            raise AppCreationError(
                error_msg,
                app_config={"host": self.host, "port": self.port},
                details={"exception": str(e)},
            )

    async def get_ssl_context(
        self, context_type: Optional[SSLContextType] = None
    ) -> Optional[Any]:
        """
        Get SSL context from SSL context manager.

        Args:
            context_type: Type of SSL context to retrieve. If None, returns based
                on SSL mode.

        Returns:
            SSL context if available, None otherwise
        """
        if not self.ssl_context_manager:
            return None

        if context_type is None:
            return None
        return await self.ssl_context_manager.get_ssl_context(context_type)

    async def get_ssl_context_summary(self) -> Dict[str, Any]:
        """
        Get SSL context manager summary.

        Returns:
            SSL context summary information
        """
        if not self.ssl_context_manager:
            return {"ssl_context_manager": None}

        return await self.ssl_context_manager.get_context_summary()

    async def create_ssl_context(
        self, context_type: SSLContextType, force_recreate: bool = False
    ) -> Optional[Any]:
        """
        Create SSL context for specified type.

        Args:
            context_type: Type of SSL context to create
            force_recreate: Whether to force recreation of existing context

        Returns:
            SSL context if created successfully, None otherwise
        """
        if not self.ssl_context_manager:
            self.logger.warning("SSL context manager not available")
            return None

        try:
            return await self.ssl_context_manager.create_ssl_context(
                context_type, force_recreate
            )
        except CustomError as e:
            self.logger.error(f"Failed to create SSL context: {e}")
            return None

    async def clear_ssl_context(self, context_type: SSLContextType) -> None:
        """
        Clear SSL context for specified type.

        Args:
            context_type: Type of SSL context to clear
        """
        if not self.ssl_context_manager:
            self.logger.warning("SSL context manager not available")
            return

        await self.ssl_context_manager.clear_context(context_type)
        self.logger.info(f"SSL context cleared for {context_type.value}")

    async def clear_all_ssl_contexts(self) -> None:
        """Clear all SSL contexts."""
        if not self.ssl_context_manager:
            self.logger.warning("SSL context manager not available")
            return

        await self.ssl_context_manager.clear_all_contexts()
        self.logger.info("All SSL contexts cleared")

