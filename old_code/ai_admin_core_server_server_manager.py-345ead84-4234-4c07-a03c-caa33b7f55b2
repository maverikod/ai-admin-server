    async def authenticate_client_token(
        self,
        token: str,
        required_permissions: Optional[List[str]] = None,
        resource: Optional[str] = None,
    ) -> Dict[str, Any]:
        """
        Authenticate client using token.

        Args:
            token: Token to authenticate with
            required_permissions: Optional list of required permissions
            resource: Optional resource identifier

        Returns:
            Authentication result dictionary

        Raises:
            AppCreationError: If token authentication fails
        """
        if not self.token_auth_manager:
            raise AppCreationError(
                "Token authentication manager not available",
                app_config={"token_auth_enabled": False},
            )

        try:
            auth_result = await self.token_auth_manager.authenticate_client(
                token=token,
                required_permissions=required_permissions,
                resource=resource,
            )

            return {
                "authenticated": auth_result.authenticated,
                "user_id": auth_result.user_id,
                "roles": auth_result.roles,
                "permissions": auth_result.permissions,
                "token_info": auth_result.token_info,
                "error_message": auth_result.error_message,
                "error_code": auth_result.error_code,
            }

        except AuthenticationError as e:
            error_msg = f"Token client authentication failed: {e}"
            self.logger.error(error_msg)
            raise AppCreationError(
                error_msg,
                app_config={"token_auth_enabled": True},
                details={"exception": str(e)},
            )

    async def validate_token(self, token: str) -> Dict[str, Any]:
        """
        Validate token.

        Args:
            token: Token to validate

        Returns:
            Token validation result dictionary

        Raises:
            AppCreationError: If token validation fails
        """
        if not self.token_auth_manager:
            raise AppCreationError(
                "Token authentication manager not available",
                app_config={"token_auth_enabled": False},
            )

        try:
            validation_result = await self.token_auth_manager.validate_token(token)

            return {
                "valid": validation_result.authenticated,
                "user_id": validation_result.user_id,
                "roles": validation_result.roles,
                "permissions": validation_result.permissions,
                "token_info": validation_result.token_info,
                "error_message": validation_result.error_message,
                "error_code": validation_result.error_code,
            }

        except ValidationError as e:
            error_msg = f"Token validation failed: {e}"
            self.logger.error(error_msg)
            raise AppCreationError(
                error_msg,
                app_config={"token_auth_enabled": True},
                details={"exception": str(e)},
            )

