def create_server(
    config_path: Optional[str] = None,
    host: str = "0.0.0.0",
    port: int = 8000,
    workers: int = 1,
    reload: bool = False,
    log_level: str = "info",
) -> "ServerManager":
    """Create and return a configured server instance."""
    from ai_admin.core.server.server_manager import ServerManager

    return ServerManager(
        config_path=config_path,
        host=host,
        port=port,
        workers=workers,
        reload=reload,
        log_level=log_level,
    )

