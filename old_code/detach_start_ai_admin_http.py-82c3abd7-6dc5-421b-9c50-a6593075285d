"""Spawn ai_admin HTTP server (python -m ai_admin) detached via subprocess.Popen(..., start_new_session=True). Logs to logs/vast_srv_http.log under project root. Parent exits immediately with child PID on stdout."""
from __future__ import annotations

import subprocess
import sys
from pathlib import Path
def main() -> None:
    root = Path(__file__).resolve().parent
    cfg = root / "config" / "config.json"
    log_dir = root / "logs"
    log_dir.mkdir(parents=True, exist_ok=True)
    log_path = log_dir / "vast_srv_http.log"
    log_f = open(log_path, "ab", buffering=0)
    proc = subprocess.Popen(
        [sys.executable, "-m", "ai_admin", "--config", str(cfg)],
        cwd=str(root),
        stdout=log_f,
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )
    log_f.close()
    print(
        f"detach_start_ai_admin_http: spawned pid={proc.pid} log={log_path}",
        flush=True,
    )


if __name__ == "__main__":
    main()

