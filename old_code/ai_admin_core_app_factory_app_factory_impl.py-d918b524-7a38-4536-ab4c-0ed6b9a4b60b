                        "/favicon.ico",
                        "/auth/login",
                        "/auth/refresh",
                    ],
                    "require_token": True,
                    "token_header": "Authorization",
                    "token_prefix": "Bearer",
                }
    
            return token_config
    
        except AuthenticationError as e:
            self.logger.warning(f"Failed to get token auth config: {e}")
            return {
                "secret_key": os.getenv("JWT_SECRET_KEY"),
                "algorithm": "HS256",
