        """
        Check if SSL is enabled.

        Returns:
            bool: True if SSL is enabled.
        """
        ssl_config = self.get_ssl_config()
        return ssl_config.is_ssl_enabled() if ssl_config else False

    def is_https_only(self) -> bool:
        """
        Check if HTTPS only mode is enabled.

        Returns:
            bool: True if HTTPS only mode is enabled.
        """
        ssl_config = self.get_ssl_config()
        return ssl_config.is_https_only() if ssl_config else False

    def is_mtls_enabled(self) -> bool:
        """
        Check if mTLS is enabled.

        Returns:
            bool: True if mTLS is enabled.
        """
        ssl_config = self.get_ssl_config()
        return ssl_config.is_mtls_enabled() if ssl_config else False

    def is_token_auth_enabled(self) -> bool:
        """
        Check if token authentication is enabled.

        Returns:
            bool: True if token authentication is enabled.
        """
        ssl_config = self.get_ssl_config()
        return ssl_config.is_token_auth_enabled() if ssl_config else False

    def get_ssl_mode(self) -> Optional[str]:
        """
        Get current SSL mode.

        Returns:
            Optional[str]: SSL mode string or None if not available.
        """
        ssl_config = self.get_ssl_config()
        return ssl_config.get_ssl_mode().value if ssl_config else None

    def get_ssl_summary(self) -> Dict[str, Any]:
        """
        Get SSL configuration summary.

        Returns:
            Dict[str, Any]: SSL configuration summary.
        """
        ssl_config = self.get_ssl_config()
        if ssl_config:
            return ssl_config.get_config_summary()
        else:
            return {
                "ssl_mode": "http_only",
                "ssl_enabled": False,
                "https_only": False,
                "mtls_enabled": False,
                "token_auth_enabled": False,
                "certificate_paths": {},
                "security_params": {},
            }

    def load_roles_config(self) -> None:
        """
        Load roles configuration from settings.

        This method loads roles configuration from the current settings
        and creates a RolesConfig instance for validation and management.
        """
        try:
            # Get roles configuration from settings
            permissions_settings = get_custom_setting_value("permissions", {})
            security_settings = get_custom_setting_value("security", {})

            # Combine permissions and security settings
            config_data = {
                "permissions": permissions_settings,
                "security": security_settings,
            }

            # Create roles config instance
            self._roles_config = RolesConfig(config_data)

            self.logger.info("🔐 Roles configuration loaded successfully")

        except ConfigurationError as e:
            self.logger.error(f"❌ Failed to load roles configuration: {e}")
            self._roles_config = None

    def validate_roles_settings(self) -> Dict[str, Any]:
        """
        Validate roles settings.

        Returns:
            Dict[str, Any]: Validation results with errors and warnings.
        """
        validation_result: Dict[str, Any] = {
            "is_valid": True,
            "errors": [],
            "warnings": [],
            "details": {},
        }

        try:
            if self._roles_config:
                # Validate roles configuration
                self._roles_config.validate_roles_config()

                # Get configuration summary
                validation_result["details"] = self._roles_config.get_config_summary()
                validation_result["is_valid"] = True

                self.logger.info("✅ Roles settings validation passed")

            else:
                validation_result["is_valid"] = False
                validation_result["errors"].append("Roles configuration not loaded")
                self.logger.warning(
                    "⚠️  Roles configuration not available for validation"
                )

        except ValueError as e:
            validation_result["is_valid"] = False
            validation_result["errors"].append(str(e))
            self.logger.error(f"❌ Roles settings validation failed: {e}")

        except ValidationError as e:
            validation_result["is_valid"] = False
            validation_result["errors"].append(
                f"Unexpected error during validation: {e}"
            )
            self.logger.error(f"❌ Unexpected error during roles validation: {e}")

        return validation_result

    def get_roles_config(self) -> Optional[RolesConfig]:
        """
        Get roles configuration instance.

        Returns:
            Optional[RolesConfig]: Roles configuration instance or None if not loaded.
        """
        return self._roles_config

    def update_roles_config(self, new_roles_settings: Dict[str, Any]) -> None:
        """
        Update roles configuration.

        Args:
            new_roles_settings: New roles settings dictionary.
        """
        try:
            if self._roles_config:
                # Update roles configuration
                self._roles_config.update_config(new_roles_settings)

                # Update settings in framework
                for key, value in new_roles_settings.items():
                    set_custom_setting_value(key, value)

                self.logger.info("✅ Roles configuration updated successfully")

            else:
                # Create new roles configuration
                self._roles_config = RolesConfig(new_roles_settings)

                # Add to framework settings
                add_custom_settings(new_roles_settings)

                self.logger.info("✅ New roles configuration created successfully")

        except ConfigurationError as e:
            self.logger.error(f"❌ Failed to update roles configuration: {e}")
            raise

    def get_roles(self) -> List[str]:
        """
        Get list of all active roles.

        Returns:
            List[str]: List of active role names.
        """
        if self._roles_config:
            return self._roles_config.get_roles()
        return []

    def get_role_permissions(self, role_name: str) -> List[str]:
        """
        Get permissions for a specific role.

        Args:
            role_name: Name of the role.

        Returns:
            List[str]: List of permission names for the role.
        """
        if self._roles_config:
            permissions = self._roles_config.get_permissions(role_name)
            return [perm.name for perm in permissions]
        return []

    def has_role_permission(self, role_name: str, permission_name: str) -> bool:
        """
        Check if a role has a specific permission.

        Args:
            role_name: Name of the role.
            permission_name: Name of the permission.

        Returns:
            bool: True if role has the permission.
        """
        if self._roles_config:
            return self._roles_config.has_permission(role_name, permission_name)
        return False

    def is_role_allowed(self, role_name: str) -> bool:
        """
        Check if a role is allowed (active and exists).

        Args:
            role_name: Name of the role.

        Returns:
            bool: True if role is allowed.
        """
        if self._roles_config:
            return self._roles_config.is_role_allowed(role_name)
        return False

    def get_roles_summary(self) -> Dict[str, Any]:
        """
        Get roles configuration summary.

        Returns:
            Dict[str, Any]: Roles configuration summary.
        """
        if self._roles_config:
            return self._roles_config.get_config_summary()
        else:
            return {
                "total_roles": 0,
                "active_roles": 0,
                "default_role": "guest",
                "admin_role": "admin",
                "certificate_mappings": 0,
                "roles": [],
                "hierarchy": {},
                "certificate_roles_mapping": {},
            }

    def load_token_config(self) -> None:
        """
        Load token configuration from settings.

        This method loads token configuration from the current settings
        and creates a TokenManager instance for validation and management.
        """
        try:
            # Get token configuration from settings
            token_settings = get_custom_setting_value("tokens", {})

            # Create token manager instance
            self._token_manager = TokenManager(token_settings)

            self.logger.info("🔑 Token configuration loaded successfully")

        except AuthenticationError as e:
            self.logger.error(f"❌ Failed to load token configuration: {e}")
            self._token_manager = None

    def validate_token_settings(self) -> Dict[str, Any]:
        """
        Validate token settings and return validation results.

        Returns:
            Dict[str, Any]: Validation results with status and details.
        """
        validation_results: Dict[str, Any] = {
            "valid": True,
            "errors": [],
            "warnings": [],
            "enabled": False,
            "total_tokens": 0,
            "active_tokens": 0,
        }

        try:
            if self._token_manager is None:
                self.load_token_config()

            if self._token_manager is None:
                validation_results["valid"] = False
                validation_results["errors"].append("Token configuration not available")
                return validation_results

            # Validate token configuration
            self._token_manager.validate_token_config()

            # Get configuration summary
            config_summary = self._token_manager.get_config_summary()
            validation_results["enabled"] = config_summary["enabled"]
            validation_results["total_tokens"] = config_summary["total_tokens"]
            validation_results["active_tokens"] = config_summary["active_tokens"]

            # Check for potential issues
            if config_summary["enabled"]:
                if config_summary["total_tokens"] == 0:
                    validation_results["warnings"].append(
                        "Token authentication enabled but no tokens configured"
                    )

                if config_summary["expired_tokens"] > 0:
                    validation_results["warnings"].append(
                        f"{config_summary['expired_tokens']} expired tokens found"
                    )

            self.logger.info(
                f"✅ Token settings validation completed: {validation_results['enabled']}"
            )

        except ValueError as e:
            validation_results["valid"] = False
            validation_results["errors"].append(str(e))
            self.logger.error(f"❌ Token settings validation failed: {e}")

        except ValidationError as e:
            validation_results["valid"] = False
            validation_results["errors"].append(f"Token validation error: {e}")
            self.logger.error(f"❌ Token settings validation error: {e}")

        return validation_results

    def get_token_config(self) -> Optional[TokenManager]:
        """
        Get token configuration instance.

        Returns:
            Optional[TokenManager]: Token manager instance or None if not available.
        """
        if self._token_manager is None:
            self.load_token_config()
        return self._token_manager

    def update_token_config(self, new_token_settings: Dict[str, Any]) -> None:
        """
        Update token configuration with new settings.

        Args:
            new_token_settings: New token settings dictionary.
        """
        try:
            # Update settings in the framework
            set_custom_setting_value("tokens", new_token_settings)

            # Reload token configuration
            self.load_token_config()

            self.logger.info("🔑 Token configuration updated successfully")

        except AuthenticationError as e:
            self.logger.error(f"❌ Failed to update token configuration: {e}")
            raise


    def validate_token(self, token_value: str) -> bool:
        """
        Validate a token value.

        Args:
            token_value: Token value to validate.

        Returns:
            bool: True if token is valid.
        """
        token_manager = self.get_token_config()
        if token_manager:
            return token_manager.validate_token(token_value)
        return False

    def is_token_valid(self, token_value: str) -> bool:
        """
        Check if a token is valid without incrementing usage.

        Args:
            token_value: Token value to check.

        Returns:
            bool: True if token is valid.
        """
        token_manager = self.get_token_config()
        if token_manager:
            return token_manager.is_token_valid(token_value)
        return False

    def get_token_roles(self, token_value: str) -> List[str]:
        """
        Get roles associated with a token.

        Args:
            token_value: Token value.

        Returns:
            List[str]: List of roles for the token.
        """
        token_manager = self.get_token_config()
        if token_manager:
            # Find token by value
            for token in token_manager.get_tokens():
                if token.token_value == token_value:
                    return token_manager.get_token_roles(token.token_id)
        return []

    def get_token_permissions(self, token_value: str) -> List[str]:
        """
        Get permissions associated with a token.

        Args:
            token_value: Token value.

        Returns:
            List[str]: List of permissions for the token.
        """
        token_manager = self.get_token_config()
        if token_manager:
            # Find token by value
            for token in token_manager.get_tokens():
                if token.token_value == token_value:
                    return token_manager.get_token_permissions(token.token_id)
        return []

    def get_token_expiry(self, token_value: str) -> Optional[datetime]:
        """
        Get expiry time for a token.

        Args:
            token_value: Token value.

        Returns:
            Optional[datetime]: Token expiry time or None if no expiry.
        """
        token_manager = self.get_token_config()
        if token_manager:
