        self,
        token_id: str,
        roles: List[str],
        permissions: Optional[List[str]] = None,
        description: Optional[str] = None,
        expires_hours: Optional[int] = None,
        max_usage: Optional[int] = None,
        metadata: Optional[Dict[str, Any]] = None,
    ) -> Optional[Any]:
        """
        Create a new token.

        Args:
            token_id: Unique token identifier.
            roles: List of roles for the token.
            permissions: List of permissions for the token.
            description: Token description.
            expires_hours: Token expiry in hours.
            max_usage: Maximum usage count.
            metadata: Additional metadata.

        Returns:
            Optional[TokenDefinition]: Created token definition or None if failed.
        """
        token_manager = self.get_token_config()
        if token_manager:
            try:
                return token_manager.create_token(
                    token_id=token_id,
                    roles=roles,
                    permissions=permissions,
                    description=description,
                    expires_hours=expires_hours,
                    max_usage=max_usage,
                    metadata=metadata,
                )
            except AuthenticationError as e:
                self.logger.error(f"❌ Failed to create token: {e}")
                return None
