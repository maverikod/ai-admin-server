import subprocess
import json
from typing import Dict, Any, Optional, List
from mcp_proxy_adapter.commands.result import SuccessResult, ErrorResult
from ai_admin.commands.base_unified_command import BaseUnifiedCommand
from ai_admin.security.docker_security_adapter import DockerSecurityAdapter

class DockerInspectCommand(BaseUnifiedCommand):
    """Get detailed information about Docker containers, images, or networks.

    This command provides detailed information about Docker objects including
    configuration, state, network settings, and more.
    """

    name = "docker_inspect"

    def __init__(self):
        """Initialize Docker inspect command."""
        super().__init__()
        self.security_adapter = DockerSecurityAdapter()

    async def execute(
        self,
        name: str,
        type_filter: Optional[str] = None,
        format_output: Optional[str] = None,
        size: bool = False,
        user_roles: Optional[List[str]] = None,
        **kwargs,
    ) -> SuccessResult:
        """Execute Docker inspect command with unified security.

        Args:
            name: Name or ID of Docker object to inspect
            type_filter: Type of object (container, image, network, volume)
            format_output: Output format (json, go template)
            size: Include size information
            user_roles: List of user roles for security validation

        Returns:
            Success result with inspection information
        """
        # Validate inputs
        if not name:
            return ErrorResult(message="Name is required", code="VALIDATION_ERROR")

        # Use unified security approach
        return await super().execute(
            name=name,
            type_filter=type_filter,
            format_output=format_output,
            size=size,
            user_roles=user_roles,
            **kwargs,
        )

    def _get_default_operation(self) -> str:
        """Get default operation name for Docker inspect command."""
        return "docker:inspect"

    async def _execute_command_logic(self, **kwargs) -> Dict[str, Any]:
        """Execute Docker inspect command logic."""
        return await self._inspect_object(**kwargs)

    async def _inspect_object(
        self,
        name: str,
        type_filter: Optional[str] = None,
        format_output: Optional[str] = None,
        size: bool = False,
        **kwargs,
    ) -> Dict[str, Any]:
        """Inspect Docker object."""
        try:
            # Build Docker command
            cmd = ["docker", "inspect"]

            # Add options
            if type_filter:
                cmd.extend(["--type", type_filter])

            if format_output:
                cmd.extend(["--format", format_output])

            if size:
                cmd.append("--size")

            # Add object name
            cmd.append(name)

            # Execute command
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)

            if result.returncode != 0:
                raise CustomError(f"Failed to inspect Docker object: {result.stderr}")

            # Parse output
            try:
                if format_output:
                    # Custom format output
                    parsed_output = result.stdout.strip()
                else:
                    # JSON output
                    parsed_output = json.loads(result.stdout)
            except json.JSONDecodeError:
                parsed_output = result.stdout.strip()

            return {
                "message": f"Inspected Docker object '{name}'",
                "name": name,
                "type_filter": type_filter,
                "format_output": format_output,
                "size": size,
                "inspection_data": parsed_output,
                "raw_output": result.stdout,
                "command": " ".join(cmd),
            }

        except subprocess.TimeoutExpired as e:
            raise CustomError(f"Docker inspect command timed out: {str(e)}")
        except CustomError as e:
            raise CustomError(f"Docker inspect failed: {str(e)}")

    @classmethod
    def get_schema(cls) -> Dict[str, Any]:
        """Get JSON schema for Docker inspect command parameters."""
        return {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Name or ID of Docker object to inspect",
                },
                "type_filter": {
                    "type": "string",
                    "description": "Type of object",
                    "enum": ["container", "image", "network", "volume"],
                },
                "format_output": {
                    "type": "string",
                    "description": "Output format (json, go template)",
                },
                "size": {
                    "type": "boolean",
                    "description": "Include size information",
                    "default": False,
                },
                "user_roles": {
                    "type": "array",
                    "items": {"type": "string"},
                    "description": "List of user roles for security validation",
                },
            },
            "required": ["name"],
            "additionalProperties": False,
        }
